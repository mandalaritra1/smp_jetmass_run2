# corrections/ is a DATA dir (EGM/JEC files), NOT a Python package.
# A stray __init__.py here turns it into a package that shadows
# corrections.py on import -> breaks get_pu_weights etc. Never track it.
smp_jetmass_run2/corrections/__init__.py
rivet/zjet_mglo_s*/

