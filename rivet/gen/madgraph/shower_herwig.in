# Herwig7 shower of the MadGraph LO Z+jet LHE file -> "mglo+herwig".
# Reads the LHE via the LesHouches interface, showers + hadronises, runs the
# CMS_ZJET_JETMASS Rivet analysis in-process. Modelled on Herwig's share/LHE.in.
#
#   Herwig read --repo=<view>/share/Herwig/HerwigDefaults.rpo -I <share> shower_herwig.in
#   Herwig run mglo_herwig.run -N <nevents>
#
# run_mg.sh substitutes __LHE__ with the unzipped MadGraph LHE path.

read snippets/PPCollider.in

cd /Herwig/EventHandlers
library LesHouches.so
create ThePEG::LesHouchesEventHandler LesHouchesHandler
set LesHouchesHandler:PartonExtractor /Herwig/Partons/PPExtractor
set LesHouchesHandler:CascadeHandler /Herwig/Shower/ShowerHandler
set LesHouchesHandler:DecayHandler /Herwig/Decays/DecayHandler
set LesHouchesHandler:HadronizationHandler /Herwig/Hadronization/ClusterHadHandler
set LesHouchesHandler:WeightOption VarNegWeight
# absolute path (the handler lives in /Herwig/EventHandlers, not /Herwig/Generators)
set /Herwig/Generators/EventGenerator:EventHandler /Herwig/EventHandlers/LesHouchesHandler

create ThePEG::Cuts /Herwig/Cuts/NoCuts

create ThePEG::LesHouchesFileReader LesHouchesReader
set LesHouchesReader:FileName __LHE__
set LesHouchesReader:AllowedToReOpen No
set LesHouchesReader:InitPDFs 0
set LesHouchesReader:Cuts /Herwig/Cuts/NoCuts
set LesHouchesReader:MomentumTreatment RescaleEnergy
# Herwig built-in LO PDF for the reader (no external LHAPDF set needed)
set LesHouchesReader:PDFA /Herwig/Partons/HardLOPDF
set LesHouchesReader:PDFB /Herwig/Partons/HardLOPDF
insert LesHouchesHandler:LesHouchesReaders 0 LesHouchesReader

# Rivet analysis hook (with shower)
read snippets/Rivet.in
insert /Herwig/Analysis/Rivet:Analyses 0 CMS_ZJET_JETMASS

cd /Herwig/Generators
saverun mglo_herwig EventGenerator
